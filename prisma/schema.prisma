datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

model ApiKey {
  id       String         @id @default(auto()) @map("_id") @db.ObjectId
  type     EnumApiKeyType @default(default)
  name     String
  key      String
  hash     String
  isActive Boolean        @default(true)
  startAt  DateTime?
  endAt    DateTime?

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@unique(fields: [key])
  @@unique(fields: [hash])
  @@index(fields: [isActive, type, createdAt(sort: Desc)])
  @@index(fields: [name])
  @@map("ApiKeys")
}

model Role {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  type        EnumRoleType  @default(user)
  scope       EnumRoleScope @default(platform)
  abilities   RoleAbility[]

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  users User[] @relation("UserRole")

  @@unique(fields: [name, scope])
  @@index(fields: [type, scope, createdAt(sort: Desc)])
  @@map("Roles")
}

model Tenant {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String @default("")
  slug        String @unique

  // timestamps fields
  createdAt DateTime  @default(now())
  createdBy String?   @db.ObjectId
  updatedAt DateTime  @updatedAt
  updatedBy String?   @db.ObjectId
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  members  TenantMember[]  @relation("TenantMembers")
  projects Project[]       @relation("TenantProjects")
  invites  TenantInvite[]  @relation("TenantInvites")

  @@index(fields: [name, createdAt])
  @@index(fields: [createdAt])
  @@map("Tenants")
}

model TenantMember {
  id       String                 @id @default(auto()) @map("_id") @db.ObjectId
  tenantId String                 @db.ObjectId
  userId   String                 @db.ObjectId
  role     EnumTenantMemberRole
  status   EnumTenantMemberStatus @default(active)

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  tenant Tenant? @relation("TenantMembers", fields: [tenantId], references: [id])
  user   User?   @relation("UserTenantMembers", fields: [userId], references: [id])

  @@unique(fields: [tenantId, userId])
  @@index(fields: [tenantId, status, createdAt])
  @@index(fields: [userId, status, createdAt])
  @@index(fields: [createdAt])
  @@map("TenantMembers")
}

model TenantInvite {
  id           String                 @id @default(auto()) @map("_id") @db.ObjectId
  tenantId     String                 @db.ObjectId
  invitedById  String                 @db.ObjectId
  invitedEmail String
  tenantRole   EnumTenantMemberRole
  type         EnumTenantInviteType
  status       EnumTenantInviteStatus @default(pending)
  token        String                 @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  revokedById  String?                @db.ObjectId

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  tenant    Tenant? @relation("TenantInvites", fields: [tenantId], references: [id])
  invitedBy User?   @relation("UserSentTenantInvites", fields: [invitedById], references: [id])

  @@index(fields: [tenantId, status, createdAt])
  @@index(fields: [token, status, expiresAt])
  @@index(fields: [invitedEmail, tenantId, status, createdAt])
  @@index(fields: [createdAt])
  @@map("TenantInvites")
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  name        String
  description String
  slug        String

  // timestamps fields
  createdAt DateTime  @default(now())
  createdBy String?   @db.ObjectId
  updatedAt DateTime  @updatedAt
  updatedBy String?   @db.ObjectId
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  tenant  Tenant          @relation("TenantProjects", fields: [tenantId], references: [id])
  members ProjectMember[] @relation("ProjectMembers")
  invites ProjectInvite[] @relation("ProjectInvites")

  @@unique(fields: [tenantId, slug])
  @@index(fields: [tenantId, deletedAt, createdAt])
  @@index(fields: [createdAt])
  @@map("Projects")
}

model ProjectInvite {
  id           String                  @id @default(auto()) @map("_id") @db.ObjectId
  invitedById  String                  @db.ObjectId
  invitedEmail String
  projectId    String                  @db.ObjectId
  projectRole  EnumProjectMemberRole
  status       EnumProjectInviteStatus @default(pending)
  token        String                  @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  sentAt       DateTime?
  revokedAt    DateTime?
  revokedById  String?                 @db.ObjectId

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  project   Project? @relation("ProjectInvites", fields: [projectId], references: [id])
  invitedBy User?    @relation("UserSentProjectInvites", fields: [invitedById], references: [id])

  @@index(fields: [projectId, status, createdAt])
  @@index(fields: [token, status, expiresAt])
  @@index(fields: [invitedEmail, projectId, status, createdAt])
  @@index(fields: [createdAt])
  @@map("ProjectInvites")
}

model ProjectMember {
  id        String                  @id @default(auto()) @map("_id") @db.ObjectId
  projectId String                  @db.ObjectId
  userId    String                  @db.ObjectId
  role      EnumProjectMemberRole
  status    EnumProjectMemberStatus @default(active)

  // timestamps fields
  createdAt DateTime  @default(now())
  createdBy String?   @db.ObjectId
  updatedAt DateTime  @updatedAt
  updatedBy String?   @db.ObjectId
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  project Project? @relation("ProjectMembers", fields: [projectId], references: [id])
  user    User?    @relation("UserProjectMembers", fields: [userId], references: [id])

  @@unique(fields: [projectId, userId])
  @@index(fields: [projectId, status, deletedAt, createdAt])
  @@index(fields: [userId, status, deletedAt, createdAt])
  @@index(fields: [role])
  @@index(fields: [createdAt])
  @@map("ProjectMembers")
}

model Country {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  alpha2Code String
  alpha3Code String
  phoneCode  String[]
  continent  String
  timezone   String

  mobileNumbers UserMobileNumber[] @relation("UserMobileNumberCountry")
  users         User[]             @relation("UserCountry")

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@unique(fields: [alpha2Code])
  @@unique(fields: [alpha3Code])
  @@index(fields: [continent])
  @@index(fields: [name])
  @@map("Countries")
}

model UserMobileNumber {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  countryId  String    @db.ObjectId
  phoneCode  String
  number     String
  isVerified Boolean   @default(false)
  verifiedAt DateTime?

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  country       Country?       @relation("UserMobileNumberCountry", fields: [countryId], references: [id])
  user          User?          @relation("UserMobileNumberUser", fields: [userId], references: [id])
  verifications Verification[] @relation("UserMobileNumberVerification")

  @@unique(fields: [userId, countryId, phoneCode, number])
  @@index(fields: [userId, isVerified])
  @@map("UserMobiles")
}

model User {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  username        String
  isVerified      Boolean            @default(false)
  verifiedAt      DateTime?
  email           String
  roleId          String             @db.ObjectId
  password        String?
  passwordExpired DateTime?
  passwordCreated DateTime?
  passwordAttempt Int?
  signUpAt        DateTime           @default(now())
  signUpFrom      EnumUserSignUpFrom
  signUpWith      EnumUserSignUpWith
  status          EnumUserStatus     @default(active)
  gender          EnumUserGender?
  countryId       String             @db.ObjectId
  lastLoginAt     DateTime?
  lastIPAddress   String?
  lastLoginFrom   EnumUserLoginFrom?
  lastLoginWith   EnumUserLoginWith?
  lastTenantId    String?            @db.ObjectId
  termPolicy      UserTermPolicy
  photo           UserPhoto?

  // timestamps fields
  createdAt DateTime  @default(now())
  createdBy String?   @db.ObjectId
  updatedAt DateTime  @updatedAt
  updatedBy String?   @db.ObjectId
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  mobileNumbers           UserMobileNumber[]         @relation("UserMobileNumberUser")
  verifications           Verification[]             @relation("UserVerifications")
  passwordHistories       PasswordHistory[]          @relation("UserPasswordHistories")
  activityLogs            ActivityLog[]              @relation("UserActivityLogs")
  role                    Role?                      @relation("UserRole", fields: [roleId], references: [id])
  country                 Country?                   @relation("UserCountry", fields: [countryId], references: [id])
  sessions                Session[]                  @relation("UserSessions")
  acceptances             TermPolicyUserAcceptance[] @relation("TermPolicyUserAcceptanceUser")
  forgotPasswords         ForgotPassword[]           @relation("UserForgotPassword")
  twoFactor               TwoFactor?                 @relation("UserTwoFactor")
  notifications           Notification[]             @relation("UserNotifications")
  notificationSettings    NotificationUserSetting[]  @relation("UserNotificationSettings")
  deviceOwnerships        DeviceOwnership[]          @relation("DeviceOwnershipUser")
  revokedSessions         Session[]                  @relation("SessionRevokedByUser")
  revokedDeviceOwnerships DeviceOwnership[]          @relation("DeviceOwnershipRevokedByUser")
  tenantMemberships       TenantMember[]             @relation("UserTenantMembers")
  projectMemberships      ProjectMember[]            @relation("UserProjectMembers")
  sentTenantInvites       TenantInvite[]             @relation("UserSentTenantInvites")
  sentProjectInvites      ProjectInvite[]            @relation("UserSentProjectInvites")

  @@unique(fields: [username])
  @@unique(fields: [email])
  @@index(fields: [id, deletedAt])
  @@index(fields: [email, deletedAt])
  @@index(fields: [status, deletedAt, createdAt(sort: Desc)])
  @@index(fields: [roleId, status, deletedAt])
  @@index(fields: [countryId, status, signUpAt(sort: Desc)])
  @@map("Users")
}

model Verification {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  userId         String               @db.ObjectId
  mobileNumberId String?              @db.ObjectId
  to             String
  type           EnumVerificationType
  token          String
  expiredAt      DateTime
  verifiedAt     DateTime?
  isUsed         Boolean              @default(false)
  reference      String
  metadata       Json?

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId

  user         User?             @relation("UserVerifications", fields: [userId], references: [id])
  mobileNumber UserMobileNumber? @relation("UserMobileNumberVerification", fields: [mobileNumberId], references: [id])

  @@unique(fields: [reference])
  @@index(fields: [token, expiredAt, isUsed, type])
  @@map("Verifications")
}

model PasswordHistory {
  id        String                  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String                  @db.ObjectId
  password  String
  type      EnumPasswordHistoryType
  expiredAt DateTime

  user User? @relation("UserPasswordHistories", fields: [userId], references: [id])

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId

  @@index(fields: [userId, expiredAt(sort: Desc)])
  @@map("PasswordHistories")
}

model ActivityLog {
  id          String                @id @default(auto()) @map("_id") @db.ObjectId
  userId      String                @db.ObjectId
  action      EnumActivityLogAction
  ipAddress   String
  userAgent   UserAgent
  geoLocation GeoLocation?
  metadata    Json?

  user User? @relation("UserActivityLogs", fields: [userId], references: [id])

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId

  @@index(fields: [userId, createdAt(sort: Desc)])
  @@index(fields: [userId, action, createdAt(sort: Desc)])
  @@map("ActivityLogs")
}

model Session {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  userId            String       @db.ObjectId
  deviceOwnershipId String       @db.ObjectId
  jti               String
  ipAddress         String
  userAgent         UserAgent
  geoLocation       GeoLocation?
  expiredAt         DateTime
  revokedAt         DateTime?
  isRevoked         Boolean      @default(false)
  revokedById       String?      @db.ObjectId

  revokedBy       User?            @relation("SessionRevokedByUser", fields: [revokedById], references: [id])
  user            User?            @relation("UserSessions", fields: [userId], references: [id])
  deviceOwnership DeviceOwnership? @relation("DeviceOwnershipSessions", fields: [deviceOwnershipId], references: [id])

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@unique(fields: [userId, jti])
  @@index(fields: [userId, expiredAt(sort: Desc), isRevoked])
  @@index(fields: [isRevoked, expiredAt(sort: Asc)])
  @@index(fields: [userId, deviceOwnershipId, isRevoked])
  @@index(fields: [deviceOwnershipId])
  @@index(fields: [createdAt])
  @@index(fields: [updatedAt])
  @@map("Sessions")
}

model Device {
  id                   String                          @id @default(auto()) @map("_id") @db.ObjectId
  fingerprint          String
  name                 String?
  platform             EnumDevicePlatform
  lastActiveAt         DateTime                        @default(now())
  notificationToken    String?
  notificationProvider EnumDeviceNotificationProvider?

  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  ownerships DeviceOwnership[] @relation("DeviceOwnershipDevice")

  @@unique(fields: [fingerprint])
  @@unique(fields: [notificationToken])
  @@map("Devices")
}

model DeviceOwnership {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  deviceId     String    @db.ObjectId
  userId       String    @db.ObjectId
  revokedAt    DateTime?
  isRevoked    Boolean   @default(false)
  revokedById  String?   @db.ObjectId
  lastActiveAt DateTime  @default(now())

  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  revokedBy User?     @relation("DeviceOwnershipRevokedByUser", fields: [revokedById], references: [id])
  device    Device    @relation("DeviceOwnershipDevice", fields: [deviceId], references: [id])
  user      User      @relation("DeviceOwnershipUser", fields: [userId], references: [id])
  sessions  Session[] @relation("DeviceOwnershipSessions")

  @@index(fields: [deviceId, revokedAt])
  @@index(fields: [userId, revokedAt])
  @@index(fields: [deviceId, userId, revokedAt])
  @@map("DeviceOwnerships")
}

model TwoFactor {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  secret        String?
  iv            String?
  backupCodes   String[]  @default([])
  enabled       Boolean   @default(false)
  requiredSetup Boolean   @default(false)
  confirmedAt   DateTime?
  lastUsedAt    DateTime?
  attempt       Int       @default(0)

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  user User? @relation("UserTwoFactor", fields: [userId], references: [id])

  @@unique(fields: [userId])
  @@map("TwoFactors")
}

model TermPolicy {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  type        EnumTermPolicyType
  contents    TermPolicyContent[]
  version     Int                  @default(1)
  status      EnumTermPolicyStatus @default(draft)
  publishedAt DateTime?

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  userAcceptances TermPolicyUserAcceptance[] @relation("TermPolicyUserAcceptanceTermPolicy")

  @@unique(fields: [type, version])
  @@index(fields: [type, status, publishedAt(sort: Desc)])
  @@map("TermPolicies")
}

model TermPolicyUserAcceptance {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  termPolicyId String   @db.ObjectId
  acceptedAt   DateTime @default(now())

  user       User?       @relation("TermPolicyUserAcceptanceUser", fields: [userId], references: [id])
  termPolicy TermPolicy? @relation("TermPolicyUserAcceptanceTermPolicy", fields: [termPolicyId], references: [id])

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId

  @@unique(fields: [userId, termPolicyId])
  @@index(fields: [termPolicyId, acceptedAt(sort: Desc)])
  @@map("TermPolicyUserAcceptances")
}

model FeatureFlag {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  key            String
  description    String
  isEnable       Boolean @default(true)
  rolloutPercent Int     @default(100)
  metadata       Json?

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@unique(fields: [key])
  @@index(fields: [isEnable])
  @@map("FeatureFlags")
}

model ForgotPassword {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  to        String
  token     String
  expiredAt DateTime
  resetAt   DateTime?
  isUsed    Boolean   @default(false)
  reference String

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId

  user User? @relation("UserForgotPassword", fields: [userId], references: [id])

  @@unique(fields: [reference])
  @@index(fields: [token, expiredAt, isUsed])
  @@map("ForgotPasswords")
}

model Notification {
  id       String                   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String                   @db.ObjectId
  type     EnumNotificationType
  priority EnumNotificationPriority @default(normal)
  title    String
  body     String
  metadata Json?
  isRead   Boolean                  @default(false)
  readAt   DateTime?

  user       User?                  @relation("UserNotifications", fields: [userId], references: [id])
  deliveries NotificationDelivery[] @relation("NotificationDeliveries")

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@index(fields: [userId, isRead, createdAt(sort: Desc)])
  @@index(fields: [userId, type, createdAt(sort: Desc)])
  @@index(fields: [userId, priority, isRead, createdAt(sort: Desc)])
  @@map("Notifications")
}

model NotificationDelivery {
  id             String                  @id @default(auto()) @map("_id") @db.ObjectId
  notificationId String                  @db.ObjectId
  channel        EnumNotificationChannel
  sentAt         DateTime?
  processedAt    DateTime?
  failureTokens  String[]                @default([])

  notification Notification @relation("NotificationDeliveries", fields: [notificationId], references: [id])

  // timestamps fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique(fields: [notificationId, channel])
  @@index(fields: [channel, createdAt(sort: Desc)])
  @@map("NotificationDeliveries")
}

model NotificationUserSetting {
  id       String                  @id @default(auto()) @map("_id") @db.ObjectId
  userId   String                  @db.ObjectId
  channel  EnumNotificationChannel
  type     EnumNotificationType
  isActive Boolean                 @default(true)

  user User? @relation("UserNotificationSettings", fields: [userId], references: [id])

  // timestamps fields
  createdAt DateTime @default(now())
  createdBy String?  @db.ObjectId
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@unique(fields: [userId, channel, type])
  @@index(fields: [userId, isActive])
  @@map("NotificationUserSettings")
}

type UserTermPolicy {
  termsOfService Boolean
  privacy        Boolean
  marketing      Boolean
  cookies        Boolean
}

type RoleAbility {
  action  String[]
  subject String
}

type UserPhoto {
  bucket       String
  key          String
  cdnUrl       String?
  completedUrl String
  mime         String
  extension    String
  access       String
}

type TermPolicyContent {
  language     String
  bucket       String
  key          String
  cdnUrl       String?
  completedUrl String
  mime         String
  extension    String
  access       String
  size         Int
}

type UserAgentBrowser {
  name    String?
  version String?
  major   String?
  type    String?
}

type UserAgentCpu {
  architecture String?
}

type UserAgentDevice {
  type   String?
  vendor String?
  model  String?
}

type UserAgentEngine {
  name    String?
  version String?
}

type UserAgentOs {
  name    String?
  version String?
}

type UserAgent {
  ua      String?
  browser UserAgentBrowser?
  cpu     UserAgentCpu?
  device  UserAgentDevice?
  engine  UserAgentEngine?
  os      UserAgentOs?
}

type GeoLocation {
  latitude  Float
  longitude Float
  country   String
  region    String
  city      String
}

enum EnumUserGender {
  male
  female
}

enum EnumUserStatus {
  active
  inactive
  blocked
}

enum EnumUserSignUpFrom {
  system
  admin
  website
  mobile
  tenant
  project
}

enum EnumUserSignUpWith {
  credential
  socialGoogle
  socialApple
}

enum EnumUserLoginFrom {
  website
  mobile
}

enum EnumUserLoginWith {
  credential
  socialGoogle
  socialApple
}

enum EnumRoleType {
  superAdmin
  admin
  user
}

enum EnumRoleScope {
  platform
  tenant
  project
}

enum EnumApiKeyType {
  system
  default
}

enum EnumTenantStatus {
  active
  inactive
}

enum EnumTenantMemberStatus {
  pending
  active
  inactive
}

enum EnumTenantMemberRole {
  owner
  admin
  member
}

enum EnumTenantInviteType {
  registered
  unregistered
}

enum EnumTenantInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum EnumProjectInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum EnumProjectMemberStatus {
  pending
  active
  inactive
}

enum EnumProjectMemberRole {
  admin
  member
  viewer
}

enum EnumTermPolicyType {
  termsOfService
  privacy
  cookies
  marketing
}

enum EnumTermPolicyStatus {
  draft
  published
}

enum EnumVerificationType {
  mobileNumber
  email
}

enum EnumPasswordHistoryType {
  signUp
  forgot
  admin
  profile
}

enum EnumActivityLogAction {
  userCreated
  userBlocked
  userUpdateStatus
  userUpdateProfile
  userUpdateNotificationSetting
  userUpdatePhotoProfile
  userChangePassword
  userDeleteSelf
  userAddMobileNumber
  userUpdateMobileNumber
  userDeleteMobileNumber
  userClaimUsername
  userUpdatePasswordByAdmin
  userLoginCredential
  userLoginGoogle
  userLoginApple
  userRefreshToken
  userVerifiedEmail
  userSendVerificationEmail
  userSendInviteEmail
  userSignedUp
  userCompleteInvite
  userResetPassword
  userRevokeSession
  userRevokeSessionByAdmin
  userRevokeAllSessions
  userRevokeAllSessionsByAdmin
  userRemoveDevice
  userAcceptTermPolicy
  userForgotPassword
  userReachMaxPasswordAttempt
  userSetupTwoFactor
  userEnableTwoFactor
  userDisableTwoFactor
  userVerifyTwoFactor
  userRegenerateTwoFactorBackupCodes
  userDeviceRefresh

  adminSessionRevoke
  adminApiKeyCreate
  adminApiKeyReset
  adminApiKeyUpdate
  adminApiKeyUpdateDate
  adminApiKeyUpdateStatus
  adminApiKeyDelete
  adminRoleCreate
  adminRoleUpdate
  adminRoleDelete
  adminTermPolicyCreate
  adminTermPolicyDelete
  adminTermPolicyUpdateContent
  adminTermPolicyAddContent
  adminTermPolicyRemoveContent
  adminTermPolicyPublish
  adminUserCreate
  adminUserUpdateStatus
  adminUserUpdatePassword
  adminUserResetTwoFactor
  adminUserImport
  adminDeviceRemove
}

enum EnumDevicePlatform {
  ios
  android
  web
}

enum EnumDeviceNotificationProvider {
  fcm
  apns
}

enum EnumNotificationType {
  securityAlert
  transactional
  userActivity
  marketing
}

enum EnumNotificationChannel {
  push
  email
  inApp
  silent
}

enum EnumNotificationPriority {
  low
  normal
  high
  critical
}
